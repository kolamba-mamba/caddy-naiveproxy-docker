# Глобальные параметры домена и SSL
# Целевой домен для маскировки и подключения прокси
DOMAIN=mirrorsite.your-domain.com
# Контактный email для регистрации ACME-аккаунта и получения уведомлений от Let's Encrypt
EMAIL=your-email@example.com

# Параметры маскировки (Heavy Camouflage)
# Ресурс, под который маскируется трафик
PROXY_SITE=https://www.example.com

# Учетные данные пользователя 1
USER1_NAME=admin
USER1_PASS=very_strong_password_1

# Учетные данные пользователя 2 (резерв)
USER2_NAME=user2
USER2_PASS=very_strong_password_2

# Учетные данные пользователя 3 (резерв)
USER3_NAME=user3
USER3_PASS=very_strong_password_3
